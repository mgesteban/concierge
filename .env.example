# ==========================================================================
# BoardBreeze Concierge — environment variables
# Copy to .env and fill in. Never commit .env.
# ==========================================================================

# --- Anthropic (Claude Opus 4.7) -------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (use SERVICE role key server-side, NEVER the anon key) -------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...

# --- Voyage AI (embeddings for the governance KB, voyage-3-lite / 512-dim) -
VOYAGE_API_KEY=pa-...

# --- Twilio (voice + SMS) --------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- ElevenLabs (text-to-speech) -------------------------------------------
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# --- Grace's phone (for escalations) ---------------------------------------
GRACE_PHONE_NUMBER=+1XXXXXXXXXX
GRACE_EMAIL=mesteban@ccsf.edu

# --- Deployment ------------------------------------------------------------
# Public base URL for this service (needed by Twilio to reach our webhooks).
# Use ngrok for local dev: https://XXXX.ngrok.io
PUBLIC_BASE_URL=https://XXXX.ngrok.io

# Server bind
HOST=0.0.0.0
PORT=8000
